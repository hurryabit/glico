{
  "manifest_version": 3,
  "name": "GitHub PR Link Copier",
  "description": "Copy a GitHub PR title and URL to the clipboard.",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Copy PR link as Markdown"
  },
  "permissions": ["tabs", "clipboardWrite"],
  "host_permissions": ["https://github.com/*"]
}
