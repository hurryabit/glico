{
  "manifest_version": 3,
  "name": "GitHub PR Link Copier",
  "description": "Copy a GitHub PR title and URL to the clipboard.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Copy PR link as Markdown",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["tabs", "clipboardWrite"],
  "host_permissions": ["https://github.com/*"]
}
